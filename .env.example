# Optional for Claude-backed Mirror analysis/coaching.
# Persist this in ~/.bashrc or your shell profile for Claude Code plugin commands.
ANTHROPIC_API_KEY=sk-ant-...

# Optional for Mem0 Cloud mode. Not needed for local_chroma mode.
MEM0_API_KEY=m0-...

# Optional for Ollama-backed specialists.
OLLAMA_BASE_URL=http://localhost:11434

# Optional override used by hooks/commands in development.
CLAUDE_PLUGIN_DATA=~/.claude/plugins/data/mirror
